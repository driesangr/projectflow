# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=projectflow
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_DB=projectflow

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://projectflow:change-me-secure-password@db/projectflow
SECRET_KEY=change-me-very-long-random-string-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Frontend (Build-Arg) ──────────────────────────────────────────────────────
# Öffentliche URL des Backends (Server-IP oder Domain, sobald vorhanden)
# Ohne Domain:   http://YOUR-SERVER-IP:8000
# Mit Domain:    https://api.yourdomain.com  (nach nginx + SSL-Setup)
VITE_API_BASE_URL=http://YOUR-SERVER-IP:8000
