# ─────────────────────────────────────────────────────────────────────────────
# Project Flow – Production Environment Variables
#
# Copy this file:  cp .env.production.example .env.production
# Then fill in all CHANGE_ME placeholders before deploying.
# NEVER commit .env.production to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=projectflow
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=projectflow

# ── Backend ───────────────────────────────────────────────────────────────────
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above
DATABASE_URL=postgresql+asyncpg://projectflow:CHANGE_ME_STRONG_PASSWORD@db/projectflow

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

ENVIRONMENT=production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Frontend / CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=https://projectflow.driesang.de
