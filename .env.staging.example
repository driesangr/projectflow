# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=projectflow
POSTGRES_PASSWORD=change-me-staging
POSTGRES_DB=projectflow

# ── Backend ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://projectflow:change-me-staging@db/projectflow
SECRET_KEY=change-me-long-random-string-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ── Frontend (Build-Arg) ──────────────────────────────────────────────────────
# URL, unter der das Backend vom Browser erreichbar ist
VITE_API_BASE_URL=http://localhost:8001
